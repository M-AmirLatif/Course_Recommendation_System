{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/backend/(.*)",
      "status": 404
    },
    {
      "src": "/docs/(.*)",
      "status": 404
    },
    {
      "src": "/tools/(.*)",
      "status": 404
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
